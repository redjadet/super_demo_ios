#!/usr/bin/env bash
# Full local delivery checklist for superDemoApp.
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

export PATH="/opt/homebrew/bin:/usr/local/bin:${PATH}"

# shellcheck source=../tool/resolve_platform_destination.sh
source "$ROOT/tool/resolve_platform_destination.sh"

IPHONE_DEST="$(resolve_iphone_destination)"
IPAD_DEST="$(resolve_ipad_destination)"
MAC_DEST="$(resolve_mac_destination)"
TEST_SERIAL_FLAGS=()

if [[ "${CHECKLIST_ALLOW_PARALLEL_TESTS:-0}" != "1" ]]; then
  TEST_SERIAL_FLAGS=(
    -parallel-testing-enabled NO
    -parallel-testing-worker-count 1
    -maximum-parallel-testing-workers 1
    -maximum-concurrent-test-simulator-destinations 1
    -maximum-concurrent-test-device-destinations 1
  )
fi

echo "==> Markdown lint"
./bin/lint-markdown.sh

echo "==> DESIGN.md lint (DesignMD)"
./tool/check_design_md.sh

echo "==> Swift lint"
./bin/lint.sh

echo "==> Common issue checks"
./tool/check_common_issues.sh

echo "==> Project/scheme sanity"
xcodebuild -list -project superDemoApp.xcodeproj

echo "==> iPhone tests ($IPHONE_DEST; builds app + tests)"
xcodebuild \
  -project superDemoApp.xcodeproj \
  -scheme superDemoApp \
  -configuration Debug \
  -destination "$IPHONE_DEST" \
  "${TEST_SERIAL_FLAGS[@]}" \
  test

if [[ "${CHECKLIST_SKIP_PLATFORM_BUILDS:-0}" != "1" ]]; then
  ./bin/ci-platform-builds.sh
else
  echo "info: skipping iPad/Mac builds because CHECKLIST_SKIP_PLATFORM_BUILDS=1"
fi

echo "Checklist passed."
